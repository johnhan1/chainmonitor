CM_APP_NAME=chainmonitor
CM_APP_ENV=staging
CM_APP_HOST=0.0.0.0
CM_APP_PORT=8000
CM_APP_LOG_LEVEL=INFO
CM_POSTGRES_DSN=postgresql+psycopg://cm:cm@postgres:5432/chainmonitor
CM_REDIS_URL=redis://redis:6379/0
CM_CLICKHOUSE_HTTP_URL=http://clickhouse:8123
CM_MINIO_ENDPOINT=http://minio:9000
CM_BSC_STRATEGY_VERSION=bsc-mvp-v1
CM_BSC_SCHEDULER_ENABLED=true
CM_BSC_SCHEDULER_INTERVAL_SECONDS=60
CM_BSC_SCHEDULER_INITIAL_DELAY_SECONDS=10
