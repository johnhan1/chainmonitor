CM_APP_NAME=chainmonitor
CM_APP_ENV=staging
CM_APP_HOST=0.0.0.0
CM_APP_PORT=8000
CM_APP_LOG_LEVEL=INFO
CM_APP_REQUIRE_API_KEY=false
CM_APP_API_KEY=
CM_APP_RATE_LIMIT_PER_MINUTE=600
CM_APP_RATE_LIMIT_BURST=120
CM_POSTGRES_DSN=postgresql+psycopg://cm:cm@postgres:5432/chainmonitor
CM_POSTGRES_POOL_SIZE=10
CM_POSTGRES_MAX_OVERFLOW=20
CM_POSTGRES_POOL_TIMEOUT_SECONDS=30
CM_POSTGRES_POOL_RECYCLE_SECONDS=1800`r`nCM_POSTGRES_STATEMENT_TIMEOUT_MS=15000`r`nCM_POSTGRES_WRITE_BATCH_SIZE=500`r`nCM_REDIS_URL=redis://redis:6379/0
CM_CLICKHOUSE_HTTP_URL=http://clickhouse:8123
CM_MINIO_ENDPOINT=http://minio:9000
CM_BSC_STRATEGY_VERSION=bsc-mvp-v1
CM_BASE_STRATEGY_VERSION=base-mvp-v1
CM_ETH_STRATEGY_VERSION=eth-mvp-v1
CM_SOL_STRATEGY_VERSION=sol-mvp-v1
CM_BSC_DEFAULT_SYMBOLS=BNB,CAKE,XVS,BUSD,USDT
CM_BASE_DEFAULT_SYMBOLS=WETH,USDC,DEGEN,AERO,BRETT
CM_ETH_DEFAULT_SYMBOLS=ETH,USDC,WBTC,PEPE,UNI
CM_SOL_DEFAULT_SYMBOLS=SOL,USDC,JUP,WIF,BONK
CM_BSC_TOKEN_ADDRESSES=
CM_BASE_TOKEN_ADDRESSES=
CM_ETH_TOKEN_ADDRESSES=
CM_SOL_TOKEN_ADDRESSES=
CM_MARKET_DATA_MODE=hybrid
CM_MARKET_DATA_TIMEOUT_SECONDS=3
CM_MARKET_DATA_RETRY_ATTEMPTS=3
CM_MARKET_DATA_RETRY_BASE_SECONDS=0.3
CM_MARKET_DATA_MAX_CONCURRENCY=8
CM_MARKET_DATA_RATE_LIMIT_PER_SECOND=10
CM_MARKET_DATA_RATE_LIMIT_CAPACITY=20
CM_MARKET_DATA_CIRCUIT_FAILURE_THRESHOLD=5
CM_MARKET_DATA_CIRCUIT_RECOVERY_SECONDS=30
CM_MARKET_DATA_CIRCUIT_HALF_OPEN_MAX_CALLS=2
CM_MARKET_DATA_MIN_SUCCESS_RATIO=0.6
CM_MARKET_DATA_MIN_PAIR_AGE_SECONDS=300
CM_MARKET_DATA_CACHE_TTL_SECONDS=3
CM_MARKET_DATA_HTTP_MAX_CONNECTIONS=100
CM_MARKET_DATA_HTTP_MAX_KEEPALIVE_CONNECTIONS=20
CM_MARKET_DATA_HTTP_KEEPALIVE_EXPIRY_SECONDS=30
CM_MARKET_DATA_RETRY_ATTEMPTS_BY_CHAIN=
CM_MARKET_DATA_MAX_CONCURRENCY_BY_CHAIN=
CM_MARKET_DATA_RATE_LIMIT_PER_SECOND_BY_CHAIN=
CM_MARKET_DATA_CIRCUIT_FAILURE_THRESHOLD_BY_CHAIN=
CM_MARKET_DATA_CIRCUIT_RECOVERY_SECONDS_BY_CHAIN=
CM_MARKET_DATA_MIN_SUCCESS_RATIO_BY_CHAIN=
CM_MARKET_DATA_MIN_PAIR_AGE_SECONDS_BY_CHAIN=
CM_MARKET_DATA_DEX_BLACKLIST_IDS=
CM_MARKET_DATA_ROUTE_BLACKLIST_KEYWORDS=
CM_INGESTION_PRIMARY_STRATEGY=dexscreener
CM_INGESTION_SECONDARY_STRATEGY=mock
CM_INGESTION_ALLOW_MOCK_IN_PRODUCTION=false
CM_GATE_MIN_LIQUIDITY_USD=150000
CM_GATE_MIN_VOLUME_5M_USD=12000
CM_GATE_MIN_TX_1M=15
CM_PIPELINE_RUN_TIMEOUT_SECONDS=30`r`nCM_PIPELINE_CANDIDATE_QUERY_CACHE_TTL_SECONDS=3`r`nCM_PIPELINE_SCHEDULER_ENABLED=true
CM_PIPELINE_SCHEDULER_INTERVAL_SECONDS=60
CM_PIPELINE_SCHEDULER_INITIAL_DELAY_SECONDS=10
CM_PIPELINE_SCHEDULER_CHAINS=bsc,base,eth,sol
CM_PIPELINE_SCHEDULER_STARTUP_JITTER_SECONDS=7
