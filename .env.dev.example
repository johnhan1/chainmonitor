CM_APP_NAME=chainmonitor
CM_APP_ENV=dev
CM_APP_HOST=0.0.0.0
CM_APP_PORT=8000
CM_APP_LOG_LEVEL=DEBUG
CM_APP_REQUIRE_API_KEY=false
CM_APP_API_KEY=
CM_APP_RATE_LIMIT_PER_MINUTE=600
CM_APP_RATE_LIMIT_BURST=120
CM_POSTGRES_DSN=postgresql+psycopg://cm:cm@localhost:5432/chainmonitor
CM_POSTGRES_POOL_SIZE=10
CM_POSTGRES_MAX_OVERFLOW=20
CM_POSTGRES_POOL_TIMEOUT_SECONDS=30
CM_POSTGRES_POOL_RECYCLE_SECONDS=1800`r`nCM_POSTGRES_STATEMENT_TIMEOUT_MS=15000`r`nCM_POSTGRES_WRITE_BATCH_SIZE=500`r`nCM_REDIS_URL=redis://localhost:6379/0
CM_CLICKHOUSE_HTTP_URL=http://localhost:8123
CM_MINIO_ENDPOINT=http://localhost:9002
CM_BSC_STRATEGY_VERSION=bsc-mvp-v1
CM_BASE_STRATEGY_VERSION=base-mvp-v1
CM_ETH_STRATEGY_VERSION=eth-mvp-v1
CM_SOL_STRATEGY_VERSION=sol-mvp-v1
