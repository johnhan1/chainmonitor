CM_MARKET_DATA_MAX_CONCURRENCY=8
CM_MARKET_DATA_RATE_LIMIT_PER_SECOND=10
CM_MARKET_DATA_RATE_LIMIT_CAPACITY=20
CM_MARKET_DATA_CIRCUIT_FAILURE_THRESHOLD=5
CM_MARKET_DATA_CIRCUIT_RECOVERY_SECONDS=30
CM_MARKET_DATA_CIRCUIT_HALF_OPEN_MAX_CALLS=2
CM_MARKET_DATA_MIN_SUCCESS_RATIO=0.6
