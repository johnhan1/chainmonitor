CM_SOL_DEFAULT_SYMBOLS=SOL,USDC,JUP,WIF,BONK
CM_BSC_TOKEN_ADDRESSES=
CM_BASE_TOKEN_ADDRESSES=
CM_ETH_TOKEN_ADDRESSES=
CM_SOL_TOKEN_ADDRESSES=
CM_MARKET_DATA_MODE=live
