CM_APP_NAME=chainmonitor
CM_APP_ENV=dev
CM_APP_HOST=0.0.0.0
CM_APP_PORT=8000
CM_APP_LOG_LEVEL=INFO
CM_POSTGRES_DSN=postgresql+psycopg://cm:cm@localhost:5432/chainmonitor
CM_REDIS_URL=redis://localhost:6379/0
CM_CLICKHOUSE_HTTP_URL=http://localhost:8123
CM_MINIO_ENDPOINT=http://localhost:9002
CM_BSC_STRATEGY_VERSION=bsc-mvp-v1
CM_BSC_SCHEDULER_ENABLED=false
CM_BSC_SCHEDULER_INTERVAL_SECONDS=60
CM_BSC_SCHEDULER_INITIAL_DELAY_SECONDS=5
